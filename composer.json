{
  "name": "optimal/file-managing",
  "description": "Simple package for file manipulation.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "image",
    "resize"
  ],
  "require": {
    "php": "^8.2",
    "ext-gd": "*",
    "claviska/simpleimage": "^4.4"
  },
  "suggest": {
    "ext-imagick": "Required only if you use ImagesManager::RESOURCE_TYPE_IMAGICK (Imagick backend). The default GD backend does not need it."
  },
  "authors": [
    {
      "name": "Radim Vidlák",
      "email": "radim.vidlak@gmail.com"
    },
    {
      "name": "Jan Jindra",
      "email": "jindra@optimal-program.cz"
    }
  ],
  "autoload": {
    "psr-4": {
      "Optimal\\FileManaging\\": "src/"
    }
  }
}
